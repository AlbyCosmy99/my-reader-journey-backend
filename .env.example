PORT=3030
SECRET_KEY=replace-with-a-long-random-secret
# SMTP (default)
MAIL_USER=your-gmail-address@gmail.com
MAIL_PASS=yourgmailapppasswordwithoutspaces
MAIL_FROM=your-gmail-address@gmail.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
MAIL_TIMEOUT_MS=10000

# Optional: use Resend instead of SMTP
# MAIL_PROVIDER=resend
# RESEND_API_KEY=re_123456789
# MAIL_FROM=My Reader Journey <noreply@yourdomain.com>
